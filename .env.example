# .env.example — X (Twitter) AI Daily Tweet Automation
# ✅ Safe to commit — no real secrets here.
# Copy this file to .env and fill in your real values.
#
#   cp .env.example .env

# ── Groq (AI Tweet Generation) ───────────────────────────────────────────────
GROQ_API_KEY=

# ── Tavily (Topic Discovery & Research) ───────────────────────────────────────
TAVILY_API_KEY=

# ── Pollinations.AI (Image Generation) ───────────────────────────────────────
POLLINATIONS_API_KEY=

# ── X (Twitter) API v2 ────────────────────────────────────────────────────────
X_API_KEY=
X_API_KEY_SECRET=
X_ACCESS_TOKEN=
X_ACCESS_TOKEN_SECRET=
X_BEARER_TOKEN=

# ── Google Sheets ─────────────────────────────────────────────────────────────
GOOGLE_SHEET_ID=
GOOGLE_CREDENTIALS_FILE=credentials/your-service-account.json
SHEET_NAME=Tweets

# ── Gmail SMTP ────────────────────────────────────────────────────────────────
GMAIL_SENDER=you@gmail.com
GMAIL_RECEIVER=you@gmail.com
GMAIL_APP_PASSWORD=

# ── Behaviour ─────────────────────────────────────────────────────────────────
POST_TIME=10:00
MAX_RETRIES=3
QUALITY_MIN_SCORE=6
